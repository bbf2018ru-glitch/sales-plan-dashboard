PORT=3000
INGEST_API_KEY=demo-secret
POSTGRES_DB=sales_dashboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/sales_dashboard

# Опциональные интеграции
DASHBOARD_PIN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LLM-маркетинг-анализ (если ключ не задан — используется встроенный rules engine)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Pull-интеграция с 1С УПП (опционально). Дашборд сам ходит в HTTP-сервис УПП.
# Если URL не задан — pull выключен (push через /api/ingest/upp работает всегда).
# UPP_PULL_INTERVAL_MIN=0 — pull только по кнопке/POST /api/upp/pull;
# UPP_PULL_INTERVAL_MIN=60 — авто-pull раз в час.
UPP_PULL_URL=
UPP_PULL_USER=
UPP_PULL_PASSWORD=
UPP_PULL_INTERVAL_MIN=0
