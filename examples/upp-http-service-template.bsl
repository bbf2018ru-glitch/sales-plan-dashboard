// HTTP-сервис: ДашбордПродажPullAPI
// URL шаблон: /dashboard/pull
// Метод: GET
// Параметры запроса (query): period=YYYY-MM (опционально, по умолчанию текущий месяц)
//
// Назначение: возвращает единый JSON-пакет в формате /api/ingest/upp дашборда.
// Дашборд периодически дергает этот сервис (UPP_PULL_URL) и сам нормализует данные.
//
// Установка:
// 1. Конфигуратор → Общие → HTTP-сервисы → Добавить «ДашбордПродажPullAPI».
// 2. Корневой URL: /dashboard, добавить шаблон URL «/pull», метод GET → обработчик ВыполнитьГет.
// 3. На вкладке «Прочее» включите Аутентификацию: Базовая (Basic). Заведите служебного пользователя.
// 4. Опубликуйте сервис на веб-сервере (Конфигуратор → Администрирование → Публикация).
// 5. URL получится вида: https://<host>/<base>/hs/dashboard/pull
//
// На стороне дашборда задайте:
//   UPP_PULL_URL=https://<host>/<base>/hs/dashboard/pull
//   UPP_PULL_USER=<служебный_пользователь>
//   UPP_PULL_PASSWORD=<пароль>
//   UPP_PULL_INTERVAL_MIN=60   ; (опционально, для авто-pull)

Функция ВыполнитьГет(Запрос) Экспорт

    Период = Запрос.ПараметрыЗапроса.Получить("period");
    Если Период = Неопределено Или ПустаяСтрока(Период) Тогда
        Период = Формат(НачалоМесяца(ТекущаяДата()), "ДФ=yyyy-MM");
    КонецЕсли;

    ПериодДата = ПериодИзСтроки(Период);
    Если ПериодДата = Неопределено Тогда
        Возврат ОтветОшибки(400, "Некорректный period, ожидается YYYY-MM");
    КонецЕсли;

    НачПериода   = НачалоМесяца(ПериодДата);
    КонПериода   = КонецМесяца(ПериодДата);
    ИдПакета     = "maria-pull-" + Формат(ТекущаяДата(), "ДФ=yyyyMMddHHmmss");

    РезПродажи = ПолучитьПродажи(НачПериода, КонПериода);
    РезПланы   = ПолучитьПланы(НачПериода, КонПериода);

    Пакет = Новый Структура;
    Пакет.Вставить("sourceSystem",     "1c-upp");
    Пакет.Вставить("sourceObject",     "pull_http_service");
    Пакет.Вставить("packageId",        ИдПакета);
    Пакет.Вставить("period",           Период);
    Пакет.Вставить("stores",           СобратьМагазины(РезПродажи, РезПланы));
    Пакет.Вставить("products",         СобратьНоменклатуру(РезПродажи));
    Пакет.Вставить("plans",            СформироватьПланы(РезПланы));
    Пакет.Вставить("sales",            СформироватьПродажи(РезПродажи));
    Пакет.Вставить("marketingMetrics", Новый Массив);

    JSON = СериализоватьJSON(Пакет);

    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(JSON, КодировкаТекста.UTF8);
    Возврат Ответ;

КонецФункции

// ── Утилиты ─────────────────────────────────────────────────────────────────

Функция ПериодИзСтроки(Стр)
    Если СтрДлина(Стр) <> 7 Или Сред(Стр, 5, 1) <> "-" Тогда
        Возврат Неопределено;
    КонецЕсли;
    Год    = Число(Лев(Стр, 4));
    Месяц  = Число(Прав(Стр, 2));
    Если Год < 2000 Или Месяц < 1 Или Месяц > 12 Тогда
        Возврат Неопределено;
    КонецЕсли;
    Возврат Дата(Год, Месяц, 1);
КонецФункции

Функция ОтветОшибки(Код, Текст)
    Ответ = Новый HTTPСервисОтвет(Код);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Ответ.УстановитьТелоИзСтроки("{""error"":""" + Текст + """}", КодировкаТекста.UTF8);
    Возврат Ответ;
КонецФункции

