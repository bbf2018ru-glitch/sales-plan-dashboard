// Модуль: ДашбордПродаж (Общий модуль, флаги: Сервер + Вызов сервера)
// Назначение: отправка данных продаж и планов из 1С УПП в дашборд.
// Запуск: через Регламентное задание раз в час.

// ─── ТОЧКА ВХОДА ──────────────────────────────────────────────────────────────

Процедура ВыполнитьВыгрузкуВДашборд() Экспорт

    // Настройки — менять здесь
    Хост   = "sales-plan-dashboard.onrender.com";
    Порт   = 443;
    Путь   = "/api/ingest/upp";
    ApiKey = "85307b26064e3764b0b19ce3223353057b0fe754b31f0f3a";

    НачалоМесяца     = НачалоМесяца(ТекущаяДата());
    КонецПериода     = КонецДня(ТекущаяДата());
    Период           = Формат(НачалоМесяца, "ДФ=yyyy-MM");
    ИдПакета         = "maria-" + Формат(ТекущаяДата(), "ДФ=yyyyMMdd-HHmmss");

    РезПродажи = ПолучитьПродажи(НачалоМесяца, КонецПериода);
    РезПланы   = ПолучитьПланы(НачалоМесяца, КонецПериода);

    Пакет = Новый Структура;
    Пакет.Вставить("sourceSystem",    "1c-upp");
    Пакет.Вставить("sourceObject",    "sales_exchange");
    Пакет.Вставить("packageId",       ИдПакета);
    Пакет.Вставить("period",          Период);
    Пакет.Вставить("stores",          СобратьМагазины(РезПродажи, РезПланы));
    Пакет.Вставить("products",        СобратьНоменклатуру(РезПродажи));
    Пакет.Вставить("plans",           СформироватьПланы(РезПланы));
    Пакет.Вставить("sales",           СформироватьПродажи(РезПродажи));
    Пакет.Вставить("marketingMetrics", Новый Массив);

    JSONСтрока = СериализоватьJSON(Пакет);
    Ответ      = ОтправитьPOST(Хост, Порт, Путь, ApiKey, JSONСтрока);
    Сообщить("Дашборд: " + Ответ);

КонецПроцедуры

// ─── ЗАПРОС ПРОДАЖ С СЕБЕСТОИМОСТЬЮ ───────────────────────────────────────────

Функция ПолучитьПродажи(НачПериода, КонПериода)

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |    Прод.Склад.Код                                      КАК СкладКод,
    |    Прод.Склад.Наименование                             КАК СкладНаим,
    |    Прод.Номенклатура.Код                               КАК ТоварКод,
    |    Прод.Номенклатура.Наименование                      КАК ТоварНаим,
    |    Прод.Номенклатура.НоменклатурнаяГруппа.Наименование КАК Категория,
    |    СУММА(Прод.КоличествоОборот)                        КАК Количество,
    |    СУММА(Прод.ВыручкаОборот)                           КАК Выручка,
    |    СУММА(Прод.СебестоимостьОборот)                     КАК Себестоимость,
    |    МАКСИМУМ(Прод.Период)                               КАК ПоследняяДата
    |ИЗ
    |    РегистрНакопления.Продажи.Обороты(
    |        &НачПериода, &КонПериода, Авто, ) КАК Прод
    |ГДЕ
    |    Прод.Склад <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
    |    И Прод.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
    |СГРУППИРОВАТЬ ПО
    |    Прод.Склад,
    |    Прод.Номенклатура";

    Запрос.УстановитьПараметр("НачПериода", НачПериода);
    Запрос.УстановитьПараметр("КонПериода", КонПериода);
    Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

// ─── ЗАПРОС ПЛАНА ПРОДАЖ ──────────────────────────────────────────────────────
// ВНИМАНИЕ: уточните у разработчика 1С из какого регистра/документа
// берётся «Идеальный результат» в отчёте «Анализ план-факта по магазинам».
// Наиболее вероятный вариант для УПП — ниже. Если не подходит — заменить запрос.

Функция ПолучитьПланы(НачПериода, КонПериода)

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |    П.Склад.Код                  КАК СкладКод,
    |    П.Склад.Наименование         КАК СкладНаим,
    |    П.Номенклатура.Код           КАК ТоварКод,
    |    П.Номенклатура.Наименование  КАК ТоварНаим,
    |    СУММА(П.СуммаОборот)         КАК СуммаПлана
    |ИЗ
    |    РегистрНакопления.ПланыПродаж.Обороты(
    |        &НачПериода, &КонПериода, Авто, ) КАК П
    |ГДЕ
    |    П.Склад <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
    |СГРУППИРОВАТЬ ПО
    |    П.Склад,
    |    П.Номенклатура";

    Запрос.УстановитьПараметр("НачПериода", НачПериода);
    Запрос.УстановитьПараметр("КонПериода", КонПериода);

    Попытка
        Возврат Запрос.Выполнить().Выгрузить();
    Исключение
        Сообщить("Планы не получены: " + ОписаниеОшибки() + " — отправляем без плана.");
        Возврат Новый ТаблицаЗначений;
    КонецПопытки;

КонецФункции

// ─── СБОРКА СТРУКТУР ──────────────────────────────────────────────────────────

Функция СобратьМагазины(ТабПродажи, ТабПланы)

    Магазины = Новый Соответствие;

    Для Каждого Стр Из ТабПродажи Цикл
        Если Не ПустаяСтрока(Стр.СкладКод) Тогда
            Магазины.Вставить(Стр.СкладКод, Новый Структура(
                "id,name,region", Стр.СкладКод, Стр.СкладНаим, "Иркутск"));
        КонецЕсли;
    КонецЦикла;

    // Добавляем магазины из планов которых нет в продажах
    Для Каждого Стр Из ТабПланы Цикл
        Если Не ПустаяСтрока(Стр.СкладКод)
            И Магазины.Получить(Стр.СкладКод) = Неопределено Тогда
            Магазины.Вставить(Стр.СкладКод, Новый Структура(
                "id,name,region", Стр.СкладКод, Стр.СкладНаим, "Иркутск"));
        КонецЕсли;
    КонецЦикла;

    Результат = Новый Массив;
    Для Каждого КЗ Из Магазины Цикл
        Результат.Добавить(КЗ.Значение);
    КонецЦикла;
    Возврат Результат;

КонецФункции

Функция СобратьНоменклатуру(ТабПродажи)

    Товары = Новый Соответствие;
    Для Каждого Стр Из ТабПродажи Цикл
        Если Не ПустаяСтрока(Стр.ТоварКод) Тогда
            Категория = Стр.Категория;
            Если ПустаяСтрока(Категория) Тогда
                Категория = "Прочее";
            КонецЕсли;
            Товары.Вставить(Стр.ТоварКод, Новый Структура(
                "id,name,category", Стр.ТоварКод, Стр.ТоварНаим, Категория));
        КонецЕсли;
    КонецЦикла;

    Результат = Новый Массив;
    Для Каждого КЗ Из Товары Цикл
        Результат.Добавить(КЗ.Значение);
    КонецЦикла;
    Возврат Результат;

КонецФункции

Функция СформироватьПланы(ТабПланы)

    Результат = Новый Массив;
    Для Каждого Стр Из ТабПланы Цикл
        Если ПустаяСтрока(Стр.СкладКод) Или ПустаяСтрока(Стр.ТоварКод) Тогда
            Продолжить;
        КонецЕсли;
        Результат.Добавить(Новый Структура(
            "storeId,productId,amount",
            Стр.СкладКод, Стр.ТоварКод, Стр.СуммаПлана));
    КонецЦикла;
    Возврат Результат;

КонецФункции

Функция СформироватьПродажи(ТабПродажи)

    Результат = Новый Массив;
    Для Каждого Стр Из ТабПродажи Цикл
        Если ПустаяСтрока(Стр.СкладКод) Или ПустаяСтрока(Стр.ТоварКод) Тогда
            Продолжить;
        КонецЕсли;

        // Дата последней продажи: если пустая — берём конец текущего дня
        Если ЗначениеЗаполнено(Стр.ПоследняяДата) Тогда
            ДатаПродажи = Формат(Стр.ПоследняяДата, "ДФ=yyyy-MM-ddTHH:mm:ss") + "+08:00";
        Иначе
            ДатаПродажи = Формат(ТекущаяДата(), "ДФ=yyyy-MM-ddTHH:mm:ss") + "+08:00";
        КонецЕсли;

        Результат.Добавить(Новый Структура(
            "storeId,productId,amount,cost,quantity,soldAt",
            Стр.СкладКод,
            Стр.ТоварКод,
            Стр.Выручка,
            Стр.Себестоимость,
            Стр.Количество,
            ДатаПродажи));
    КонецЦикла;
    Возврат Результат;

КонецФункции

// ─── HTTP ─────────────────────────────────────────────────────────────────────

Функция СериализоватьJSON(Значение)

    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Значение);
    Возврат ЗаписьJSON.Закрыть();

КонецФункции

Функция ОтправитьPOST(Хост, Порт, Путь, ApiKey, ТелоJSON)

    Защита     = Новый ЗащищенноеСоединениеOpenSSL();
    Соединение = Новый HTTPСоединение(Хост, Порт,,,, 60, Защита);
    Запрос     = Новый HTTPЗапрос(Путь);
    Запрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Запрос.Заголовки.Вставить("X-API-Key", ApiKey);
    // Два параметра — без BOM, работает во всех версиях 8.3
    Запрос.УстановитьТелоИзСтроки(ТелоJSON, КодировкаТекста.UTF8);

    Ответ        = Соединение.ОтправитьДляОбработки(Запрос);
    ОтветСтрокой = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);

    Если Ответ.КодСостояния <> 200 Тогда
        ВызватьИсключение "Дашборд HTTP=" + Ответ.КодСостояния + ": " + ОтветСтрокой;
    КонецЕсли;

    Возврат ОтветСтрокой;

КонецФункции
