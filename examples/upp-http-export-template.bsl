Процедура ВыполнитьВыгрузкуВДашборд() Экспорт

    АдресСервиса = "https://sales-plan-dashboard.onrender.com/api/ingest/upp";
    ApiKey = "85307b26064e3764b0b19ce3223353057b0fe754b31f0f3a";
    Период = Формат(ТекущаяДата(), "ДФ=yyyy-MM");
    ИдентификаторПакета = "upp-" + Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd-HHmmss");

    Пакет = Новый Структура;
    Пакет.Вставить("sourceSystem", "1c-upp");
    Пакет.Вставить("sourceObject", "regulated_exchange");
    Пакет.Вставить("packageId", ИдентификаторПакета);
    Пакет.Вставить("period", Период);
    Пакет.Вставить("stores", ПолучитьТочки());
    Пакет.Вставить("products", ПолучитьНоменклатуру());
    Пакет.Вставить("plans", ПолучитьПланыПродаж(Период));
    Пакет.Вставить("sales", ПолучитьПродажи(Период));
    Пакет.Вставить("marketingMetrics", ПолучитьМаркетинг(Период));

    JSONСтрока = СериализоватьJSON(Пакет);
    Ответ = ОтправитьPOST(АдресСервиса, ApiKey, JSONСтрока);

    Сообщить("Ответ дашборда: " + Ответ);

КонецПроцедуры

