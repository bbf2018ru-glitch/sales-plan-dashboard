// Шаблон внешней обработки / общего модуля для 1С:УПП «Мария».
// Запрашивает данные из РегистрНакопления.Продажи и плана продаж,
// формирует единый JSON-пакет и отправляет в дашборд.
//
// Запуск: вручную или через Регламентное задание (рекомендуется раз в час).

Перем АдресСервиса = "https://sales-plan-dashboard.onrender.com/api/ingest/upp";
Перем ApiKey        = "85307b26064e3764b0b19ce3223353057b0fe754b31f0f3a";

// ─── ТОЧКА ВХОДА ──────────────────────────────────────────────────────────────

Процедура ВыполнитьВыгрузкуВДашборд() Экспорт

    НачалоМесяца = НачалоМесяца(ТекущаяДата());
    КонецПериода = КонецДня(ТекущаяДата());
    Период = Формат(НачалоМесяца, "ДФ=yyyy-MM");
    ИдентификаторПакета = "maria-" + Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd-HHmmss");

    Пакет = Новый Структура;
    Пакет.Вставить("sourceSystem", "1c-upp");
    Пакет.Вставить("sourceObject", "sales_exchange");
    Пакет.Вставить("packageId",    ИдентификаторПакета);
    Пакет.Вставить("period",       Период);

    // Получаем данные
    РезПродажи = ПолучитьПродажи(НачалоМесяца, КонецПериода);
    РезПланы   = ПолучитьПланы(НачалоМесяца, КонецПериода);

    Пакет.Вставить("stores",          СобратьМагазины(РезПродажи, РезПланы));
    Пакет.Вставить("products",        СобратьНоменклатуру(РезПродажи));
    Пакет.Вставить("plans",           СформироватьПланы(РезПланы, Период));
    Пакет.Вставить("sales",           СформироватьПродажи(РезПродажи, Период));
    Пакет.Вставить("marketingMetrics", Новый Массив); // заполнить при необходимости

    JSONСтрока = СериализоватьJSON(Пакет);
    Ответ = ОтправитьPOST(АдресСервиса, ApiKey, JSONСтрока);
    Сообщить("Дашборд: " + Ответ);

КонецПроцедуры

// ─── ЗАПРОС ПРОДАЖ С СЕБЕСТОИМОСТЬЮ ───────────────────────────────────────────
// Источник: РегистрНакопления.Продажи
// Поля отчёта «Валовая прибыль»: Склад, Номенклатура, Количество,
//   Сумма со скидкой (ВыручкаОборот), Себестоимость (СебестоимостьОборот)

Функция ПолучитьПродажи(НачПериода, КонПериода)

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |    Прод.Склад.Код                                      КАК СкладКод,
    |    Прод.Склад.Наименование                             КАК СкладНаим,
    |    Прод.Номенклатура.Код                               КАК ТоварКод,
    |    Прод.Номенклатура.Наименование                      КАК ТоварНаим,
    |    Прод.Номенклатура.НоменклатурнаяГруппа.Наименование КАК Категория,
    |    СУММА(Прод.КоличествоОборот)                        КАК Количество,
    |    СУММА(Прод.ВыручкаОборот)                           КАК Выручка,
    |    СУММА(Прод.СебестоимостьОборот)                     КАК Себестоимость,
    |    МАКСИМУМ(Прод.Период)                               КАК ПоследняяДата
    |ИЗ
    |    РегистрНакопления.Продажи.Обороты(
    |        &НачПериода, &КонПериода, Авто, ) КАК Прод
    |ГДЕ
    |    Прод.Склад <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
    |    И Прод.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
    |СГРУППИРОВАТЬ ПО
    |    Прод.Склад,
    |    Прод.Номенклатура";

    Запрос.УстановитьПараметр("НачПериода", НачПериода);
    Запрос.УстановитьПараметр("КонПериода", КонПериода);
    Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

// ─── ЗАПРОС ПЛАНА ПРОДАЖ ──────────────────────────────────────────────────────
// В отчёте «Анализ план-факта по магазинам» план хранится как
// «Идеальный результат» раздел «Отгрузка» — по магазинам без разбивки по товарам.
//
// ВНИМАНИЕ: уточните у разработчика 1С из какого регистра/документа
// берётся «Идеальный результат» в вашем отчёте.
// Ниже — наиболее вероятный вариант для УПП:

Функция ПолучитьПланы(НачПериода, КонПериода)

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |    ПланПрод.Склад.Код              КАК СкладКод,
    |    ПланПрод.Склад.Наименование     КАК СкладНаим,
    |    ПланПрод.Номенклатура.Код       КАК ТоварКод,
    |    ПланПрод.Номенклатура.Наименование КАК ТоварНаим,
    |    СУММА(ПланПрод.СуммаОборот)     КАК СуммаПлана
    |ИЗ
    |    РегистрНакопления.ПланыПродаж.Обороты(
    |        &НачПериода, &КонПериода, Авто, ) КАК ПланПрод
    |ГДЕ
    |    ПланПрод.Склад <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
    |СГРУППИРОВАТЬ ПО
    |    ПланПрод.Склад,
    |    ПланПрод.Номенклатура";

    // Если регистр называется иначе или план хранится в документе —
    // замените запрос. Например, в некоторых конфигурациях:
    //   РегистрСведений.ПланыПродажПоМагазинам
    //   или ДокументСписок.ПланированиеПродаж

    Запрос.УстановитьПараметр("НачПериода", НачПериода);
    Запрос.УстановитьПараметр("КонПериода", КонПериода);

    Попытка
        Возврат Запрос.Выполнить().Выгрузить();
    Исключение
        Сообщить("Планы: " + ОписаниеОшибки() + " — отправляем без плана.");
        Возврат Новый ТаблицаЗначений;
    КонецПопытки;

КонецФункции

// ─── СБОРКА ОБЪЕКТОВ ──────────────────────────────────────────────────────────

Функция СобратьМагазины(ТабПродажи, ТабПланы)

    Магазины = Новый Соответствие;

    Для Каждого Стр Из ТабПродажи Цикл
        Если Не ПустаяСтрока(Стр.СкладКод) Тогда
            Магазины.Вставить(Стр.СкладКод, Новый Структура(
                "id,name,region", Стр.СкладКод, Стр.СкладНаим, "Иркутск"));
        КонецЕсли;
    КонецЦикла;

    Для Каждого Стр Из ТабПланы Цикл
        Если Не ПустаяСтрока(Стр.СкладКод) И Не Магазины.Получить(Стр.СкладКод) = Неопределено Тогда
            Магазины.Вставить(Стр.СкладКод, Новый Структура(
                "id,name,region", Стр.СкладКод, Стр.СкладНаим, "Иркутск"));
        КонецЕсли;
    КонецЦикла;

    Результат = Новый Массив;
    Для Каждого КЗ Из Магазины Цикл
        Результат.Добавить(КЗ.Значение);
    КонецЦикла;
    Возврат Результат;

КонецФункции

Функция СобратьНоменклатуру(ТабПродажи)

    Товары = Новый Соответствие;
    Для Каждого Стр Из ТабПродажи Цикл
        Если Не ПустаяСтрока(Стр.ТоварКод) Тогда
            Товары.Вставить(Стр.ТоварКод, Новый Структура(
                "id,name,category",
                Стр.ТоварКод,
                Стр.ТоварНаим,
                ?(ПустаяСтрока(Стр.Категория), "Прочее", Стр.Категория)));
        КонецЕсли;
    КонецЦикла;

    Результат = Новый Массив;
    Для Каждого КЗ Из Товары Цикл
        Результат.Добавить(КЗ.Значение);
    КонецЦикла;
    Возврат Результат;

КонецФункции

Функция СформироватьПланы(ТабПланы, Период)

    Результат = Новый Массив;
    Для Каждого Стр Из ТабПланы Цикл
        Если ПустаяСтрока(Стр.СкладКод) Или ПустаяСтрока(Стр.ТоварКод) Тогда
            Продолжить;
        КонецЕсли;
        Стр_ = Новый Структура("storeId,productId,amount",
            Стр.СкладКод, Стр.ТоварКод, Стр.СуммаПлана);
        Результат.Добавить(Стр_);
    КонецЦикла;
    Возврат Результат;

КонецФункции

Функция СформироватьПродажи(ТабПродажи, Период)

    Результат = Новый Массив;
    Для Каждого Стр Из ТабПродажи Цикл
        Если ПустаяСтрока(Стр.СкладКод) Или ПустаяСтрока(Стр.ТоварКод) Тогда
            Продолжить;
        КонецЕсли;
        Стр_ = Новый Структура(
            "storeId,productId,amount,cost,quantity,soldAt",
            Стр.СкладКод,
            Стр.ТоварКод,
            Стр.Выручка,         // Сумма со скидкой = ВыручкаОборот
            Стр.Себестоимость,   // СебестоимостьОборот
            Стр.Количество,
            Формат(Стр.ПоследняяДата, "ДФ=yyyy-MM-ddTHH:mm:ss") + "+08:00"
        );
        Результат.Добавить(Стр_);
    КонецЦикла;
    Возврат Результат;

КонецФункции

// ─── HTTP ─────────────────────────────────────────────────────────────────────

Функция СериализоватьJSON(Значение)

    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Значение);
    Возврат ЗаписьJSON.Закрыть();

КонецФункции

Функция ОтправитьPOST(АдресСервиса, ApiKey, ТелоJSON)

    URI = Новый URI(АдресСервиса);
    Защита = Новый ЗащищенноеСоединениеOpenSSL();
    Соединение = Новый HTTPСоединение(URI.Хост, URI.Порт,,,, 60, Защита);
    Запрос = Новый HTTPЗапрос(URI.Путь);
    Запрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Запрос.Заголовки.Вставить("X-API-Key", ApiKey);
    Запрос.УстановитьТелоИзСтроки(ТелоJSON, КодировкаТекста.UTF8,
        ИспользованиеByteOrderMark.НеИспользовать);

    Ответ = Соединение.ОтправитьДляОбработки(Запрос);
    ОтветСтрокой = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);

    Если Ответ.КодСостояния <> 200 Тогда
        ВызватьИсключение "Дашборд HTTP=" + Ответ.КодСостояния + ": " + ОтветСтрокой;
    КонецЕсли;

    Возврат ОтветСтрокой;

КонецФункции
