// ============================================================
// Модуль обмена с дашбордом продаж
// Вставить в: Общий модуль или Внешняя обработка (ВыгрузитьДанные)
// Запускать через Регламентное задание раз в час (или вручную)
// ============================================================

// ─── Настройки ──────────────────────────────────────────────
Перем АдресСервера   = "your-dashboard.onrender.com"; // без https://
Перем КлючAPI        = "demo-secret";                 // INGEST_API_KEY на сервере
Перем ТаймаутСек     = 30;

// ============================================================
// ТОЧКА ВХОДА
// ============================================================
Процедура ВыгрузитьДанные() Экспорт

    НачалоМесяца = НачалоМесяца(ТекущаяДата());
    КонецПериода = КонецДня(ТекущаяДата());
    Период = Формат(НачалоМесяца, "ДФ=yyyy-MM");

    // 1. Планы
    ВыгрузитьПланы(Период, НачалоМесяца, КонецПериода);

    // 2. Факт продаж с себестоимостью
    ВыгрузитьПродажи(Период, НачалоМесяца, КонецПериода);

КонецПроцедуры

// ============================================================
// ПЛАНЫ ПРОДАЖ
// ============================================================
Процедура ВыгрузитьПланы(Период, НачПериода, КонПериода)

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |    ПланПродаж.Номенклатура.Код             КАК ТоварКод,
    |    ПланПродаж.Номенклатура.Наименование    КАК ТоварНаим,
    |    ПланПродаж.Номенклатура.ВидНоменклатуры.Наименование КАК Категория,
    |    ПланПродаж.Склад.Код                    КАК СкладКод,
    |    ПланПродаж.Склад.Наименование           КАК СкладНаим,
    |    ПланПродаж.Склад.Регион                 КАК Регион,
    |    СУММА(ПланПродаж.КоличествоОборот * ПланПродаж.Номенклатура.ЦенаПродажи) КАК СуммаПлана
    |ИЗ
    |    РегистрНакопления.ПланыПродаж.Обороты(&НачПериода, &КонПериода, Авто, ) КАК ПланПродаж
    |ГДЕ
    |    ПланПродаж.Склад <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
    |    И ПланПродаж.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
    |СГРУППИРОВАТЬ ПО
    |    ПланПродаж.Номенклатура,
    |    ПланПродаж.Склад";

    // ПРИМЕЧАНИЕ: если планы хранятся в сумме (не кол-во × цена),
    // замените выражение суммы на нужное поле, например ПланПродаж.СуммаОборот

    Запрос.УстановитьПараметр("НачПериода", НачПериода);
    Запрос.УстановитьПараметр("КонПериода", КонПериода);

    Результат = Запрос.Выполнить().Выгрузить();

    Если Результат.Количество() = 0 Тогда
        Возврат;
    КонецЕсли;

    // Собираем уникальные склады и товары
    Склады  = Новый Соответствие;
    Товары  = Новый Соответствие;
    Планы   = Новый Массив;

    Для Каждого Стр Из Результат Цикл
        Склады.Вставить(Стр.СкладКод, Новый Структура("id,name,region",
            Стр.СкладКод, Стр.СкладНаим, СтрЗначениеРегиона(Стр.Регион)));
        Товары.Вставить(Стр.ТоварКод, Новый Структура("id,name,category",
            Стр.ТоварКод, Стр.ТоварНаим, ?(ПустаяСтрока(Стр.Категория), "Прочее", Стр.Категория)));

        ЭлПлан = Новый Структура("storeId,productId,amount",
            Стр.СкладКод, Стр.ТоварКод, Стр.СуммаПлана);
        Планы.Добавить(ЭлПлан);
    КонецЦикла;

    Тело = Новый Структура;
    Тело.Вставить("period",   Период);
    Тело.Вставить("stores",   МассивИзСоответствия(Склады));
    Тело.Вставить("products", МассивИзСоответствия(Товары));
    Тело.Вставить("plans",    Планы);

    ОтправитьJSON("/api/ingest/plans", Тело);

КонецПроцедуры

// ============================================================
// ФАКТ ПРОДАЖ + СЕБЕСТОИМОСТЬ
// ============================================================
Процедура ВыгрузитьПродажи(Период, НачПериода, КонПериода)

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |    Продажи.Номенклатура.Код                КАК ТоварКод,
    |    Продажи.Номенклатура.Наименование       КАК ТоварНаим,
    |    Продажи.Номенклатура.ВидНоменклатуры.Наименование КАК Категория,
    |    Продажи.Склад.Код                       КАК СкладКод,
    |    Продажи.Склад.Наименование              КАК СкладНаим,
    |    Продажи.Склад.Регион                    КАК Регион,
    |    СУММА(Продажи.КоличествоОборот)         КАК Количество,
    |    СУММА(Продажи.ВыручкаОборот)            КАК Выручка,
    |    СУММА(Продажи.СебестоимостьОборот)      КАК Себестоимость,
    |    МАКСИМУМ(Продажи.Период)                КАК ПоследняяДата
    |ИЗ
    |    РегистрНакопления.Продажи.Обороты(&НачПериода, &КонПериода, Авто, ) КАК Продажи
    |ГДЕ
    |    Продажи.Склад <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
    |    И Продажи.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
    |СГРУППИРОВАТЬ ПО
    |    Продажи.Номенклатура,
    |    Продажи.Склад";

    Запрос.УстановитьПараметр("НачПериода", НачПериода);
    Запрос.УстановитьПараметр("КонПериода", КонПериода);

    Результат = Запрос.Выполнить().Выгрузить();

    Если Результат.Количество() = 0 Тогда
        Возврат;
    КонецЕсли;

    Склады  = Новый Соответствие;
    Товары  = Новый Соответствие;
    Продажи = Новый Массив;

    Для Каждого Стр Из Результат Цикл
        Склады.Вставить(Стр.СкладКод, Новый Структура("id,name,region",
            Стр.СкладКод, Стр.СкладНаим, СтрЗначениеРегиона(Стр.Регион)));
        Товары.Вставить(Стр.ТоварКод, Новый Структура("id,name,category",
            Стр.ТоварКод, Стр.ТоварНаим, ?(ПустаяСтрока(Стр.Категория), "Прочее", Стр.Категория)));

        ЭлПродажа = Новый Структура(
            "storeId,productId,amount,cost,quantity,soldAt",
            Стр.СкладКод,
            Стр.ТоварКод,
            Стр.Выручка,
            Стр.Себестоимость,
            Стр.Количество,
            Формат(Стр.ПоследняяДата, "ДФ=yyyy-MM-ddTHH:mm:ss") + "+08:00"
        );
        Продажи.Добавить(ЭлПродажа);
    КонецЦикла;

    Тело = Новый Структура;
    Тело.Вставить("period",   Период);
    Тело.Вставить("replace",  Истина); // заменяем весь период — без дублей
    Тело.Вставить("stores",   МассивИзСоответствия(Склады));
    Тело.Вставить("products", МассивИзСоответствия(Товары));
    Тело.Вставить("sales",    Продажи);

    ОтправитьJSON("/api/ingest/sales", Тело);

КонецПроцедуры

// ============================================================
// ВСПОМОГАТЕЛЬНЫЕ
// ============================================================

// Отправляет структуру как JSON POST на сервер
Процедура ОтправитьJSON(Путь, Данные)

    ЗаписьJSON = Новый ЗаписьJSON;
    НастройкиJSON = Новый НастройкиСериализацииJSON;
    НастройкиJSON.ФорматДаты = ФорматДатыJSON.ISO;
    ЗаписьJSON.УстановитьСтроку(НастройкиJSON);
    ЗаписатьJSON(ЗаписьJSON, Данные);
    ТекстJSON = ЗаписьJSON.Закрыть();

    Защита   = Новый ЗащищенноеСоединениеOpenSSL();
    Соединение = Новый HTTPСоединение(АдресСервера, 443, , , , ТаймаутСек, Защита);
    Запрос = Новый HTTPЗапрос(Путь);
    Запрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Запрос.Заголовки.Вставить("X-API-Key", КлючAPI);
    Запрос.УстановитьТелоИзСтроки(ТекстJSON, КодировкаТекста.UTF8);

    Попытка
        Ответ = Соединение.ОтправитьДляОбработки(Запрос);
        Если Ответ.КодСостояния <> 200 Тогда
            Сообщить("Дашборд [" + Путь + "]: ошибка " + Ответ.КодСостояния
                + " — " + Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8));
        КонецЕсли;
    Исключение
        Сообщить("Дашборд [" + Путь + "]: " + ОписаниеОшибки());
    КонецПопытки;

КонецПроцедуры

// Преобразует Соответствие<ключ → Структура> в Массив структур
Функция МассивИзСоответствия(Соответствие)
    Результат = Новый Массив;
    Для Каждого КЗ Из Соответствие Цикл
        Результат.Добавить(КЗ.Значение);
    КонецЦикла;
    Возврат Результат;
КонецФункции

// Возвращает строковое значение региона (может быть строкой или перечислением)
Функция СтрЗначениеРегиона(Значение)
    Если ТипЗнч(Значение) = Тип("Строка") Тогда
        Возврат Значение;
    КонецЕсли;
    Возврат Строка(Значение);
КонецФункции
